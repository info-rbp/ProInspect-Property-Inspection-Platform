{
  "name": "@pcr/templates",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {"types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js"},
    "./pcr-preset": {"types": "./dist/pcrPreset.d.ts", "import": "./dist/pcrPreset.js", "default": "./dist/pcrPreset.js"},
    "./registry": {"types": "./dist/registry.d.ts", "import": "./dist/registry.js", "default": "./dist/registry.js"},
    "./presets/wa": {"types": "./dist/presets/wa/index.d.ts", "import": "./dist/presets/wa/index.js", "default": "./dist/presets/wa/index.js"}
  },
  "scripts": {"typecheck": "tsc --noEmit -p tsconfig.json", "test:run": "vitest run --passWithNoTests", "build": "tsc -p tsconfig.build.json"},
  "dependencies": {"@pcr/domain": "*", "@pcr/validation": "*"},
  "files": ["dist"]
}
