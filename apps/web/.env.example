# Copy this file to apps/web/.env.local and fill in real values.
# apps/web/.env.local is git-ignored (see repo-root .gitignore's `*.local`
# rule) — never commit real keys. Vite only reads VITE_-prefixed vars from
# the workspace it builds (apps/web), so env files MUST live here, not at
# the repo root.
#
# After editing this file, rebuild the web app so the values are baked
# into the bundle:
#   npm run build:packages && npm run build --workspace @pcr/web

# ---------------------------------------------------------------------------
# AI Commentary (Settings page "AI Commentary" card)
# ---------------------------------------------------------------------------
# Base URL of the deployed Cloud Run API that proxies the server-managed
# Vertex AI commentary workflow. Leave empty locally to keep the app in
# API-disconnected mode; the Settings page will show "Needs attention" and
# apiClient.ts will fail closed with a clear error instead of calling out
# to an unset endpoint.
VITE_API_BASE_URL=

# ---------------------------------------------------------------------------
# Firebase / Identity Platform (Settings page "Firebase" card)
# ---------------------------------------------------------------------------
# All six values below must be set together, or none are used — see
# hasCompleteFirebaseConfig() in services/configService.ts. Get these from
# Firebase Console > Project settings > General > Your apps > SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: enables Firebase App Check (App Attest / reCAPTCHA Enterprise)
# on outgoing API calls. Leave empty to skip App Check token attachment.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# ---------------------------------------------------------------------------
# Application identity shown in the shared shell.
# ---------------------------------------------------------------------------
VITE_APP_NAME=ProInspect
VITE_APP_VERSION=development

# Supported values: local, development, staging, production.
VITE_APP_ENVIRONMENT=local
