{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {"@/*": ["./*"]},
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"]
}
